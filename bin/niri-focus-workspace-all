#!/usr/bin/env bash
set -euo pipefail

direction="${1:-}"
case "$direction" in
  down|up) ;;
  *)
    echo "usage: niri-focus-workspace-all down|up" >&2
    exit 2
    ;;
esac

if ! command -v jq >/dev/null 2>&1; then
  echo "niri-focus-workspace-all: jq is required" >&2
  exit 1
fi

if command -v flock >/dev/null 2>&1; then
  exec 9>"${XDG_RUNTIME_DIR:-/tmp}/niri-focus-workspace-all.lock"
  flock -n 9 || exit 0
fi

workspaces="$(niri msg -j workspaces)"
focused="$(jq -e -c '.[] | select(.is_focused == true)' <<<"$workspaces")"

current_idx="$(jq -r '.idx' <<<"$focused")"
focused_output="$(jq -r '.output' <<<"$focused")"

case "$direction" in
  down) target_idx=$((current_idx + 1)) ;;
  up) target_idx=$((current_idx - 1)) ;;
esac

if (( target_idx < 1 )); then
  exit 0
fi

mapfile -t active_outputs < <(
  jq -r '.[] | select(.is_active == true) | .output' <<<"$workspaces"
)

for output in "${active_outputs[@]}"; do
  if ! jq -e --arg output "$output" --argjson target_idx "$target_idx" \
    '.[] | select(.output == $output and .idx == $target_idx)' \
    <<<"$workspaces" >/dev/null; then
    exit 0
  fi
done

active_idx_for() {
  niri msg -j workspaces \
    | jq -r --arg output "$1" '.[] | select(.output == $output and .is_active == true) | .idx'
}

restore_focus() {
  niri msg action focus-monitor "$focused_output" >/dev/null 2>&1 || true
}
trap restore_focus EXIT

for output in "${active_outputs[@]}"; do
  [[ -n "$output" ]] || continue
  niri msg action focus-monitor "$output" >/dev/null || continue

  for _ in {1..20}; do
    active_idx="$(active_idx_for "$output")"
    [[ -n "$active_idx" ]] || break

    if (( active_idx == target_idx )); then
      break
    elif (( active_idx < target_idx )); then
      niri msg action focus-workspace-down >/dev/null
    else
      niri msg action focus-workspace-up >/dev/null
    fi

    next_idx="$(active_idx_for "$output")"
    if [[ -z "$next_idx" || "$next_idx" == "$active_idx" ]]; then
      break
    fi
  done
done

restore_focus
trap - EXIT
