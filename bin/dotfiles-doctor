#!/usr/bin/env bash
set -uo pipefail

failures=0
warnings=0
issue_levels=()
issue_messages=()

if [[ -t 1 && -z "${NO_COLOR:-}" && "${TERM:-}" != "dumb" ]]; then
  reset=$'\033[0m'
  bold=$'\033[1m'
  green=$'\033[32m'
  blue=$'\033[34m'
  yellow=$'\033[33m'
  red=$'\033[31m'
else
  reset=""
  bold=""
  green=""
  blue=""
  yellow=""
  red=""
fi

ok() {
  printf '%s✓%s %s\n' "$green" "$reset" "$*"
}

info() {
  printf '%s●%s %s\n' "$blue" "$reset" "$*"
}

warn() {
  warnings=$((warnings + 1))
  issue_levels+=(warn)
  issue_messages+=("$*")
  printf '%s⚠%s %s\n' "$yellow" "$reset" "$*"
}

fail() {
  failures=$((failures + 1))
  issue_levels+=(fail)
  issue_messages+=("$*")
  printf '%s✗%s %s\n' "$red" "$reset" "$*"
}

section() {
  printf '\n%s◆ %s%s\n' "$bold$blue" "$*" "$reset"
}

print_issues() {
  local i

  ((${#issue_messages[@]})) || return
  section "issues"
  for i in "${!issue_messages[@]}"; do
    if [[ "${issue_levels[$i]}" == "fail" ]]; then
      printf '%s✗%s %s\n' "$red" "$reset" "${issue_messages[$i]}"
    else
      printf '%s⚠%s %s\n' "$yellow" "$reset" "${issue_messages[$i]}"
    fi
  done
}

print_summary() {
  section "summary"
  if ((failures > 0)); then
    printf '%s✗%s doctor found %d failure(s), %d warning(s)\n' \
      "$red" "$reset" "$failures" "$warnings"
  elif ((warnings > 0)); then
    printf '%s⚠%s doctor found %d warning(s)\n' "$yellow" "$reset" "$warnings"
  else
    printf '%s✓%s doctor found no issues\n' "$green" "$reset"
  fi
  print_issues
}

have() {
  command -v "$1" >/dev/null 2>&1
}

is_wsl() {
  [[ -n "${WSL_DISTRO_NAME:-}" ]] || grep -qiE "(microsoft|wsl)" /proc/version 2>/dev/null
}

is_debian_like() {
  local id="" id_like=""

  if [[ -f /etc/os-release ]]; then
    id="$(awk -F= '$1 == "ID" { gsub(/"/, "", $2); print $2 }' /etc/os-release)"
    id_like="$(awk -F= '$1 == "ID_LIKE" { gsub(/"/, "", $2); print $2 }' /etc/os-release)"
  fi

  case " $id $id_like " in
    *" ubuntu "*|*" debian "*) return 0 ;;
    *) return 1 ;;
  esac
}

same_path() {
  [[ "$(readlink -f "$1" 2>/dev/null || true)" == "$(readlink -f "$2" 2>/dev/null || true)" ]]
}

resolve_dotfiles_dir() {
  local script_dir candidate
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  for candidate in \
    "${DOTFILES_DIR:-}" \
    "$script_dir/.." \
    "$PWD" \
    "$HOME/.dotfiles" \
    "$HOME/dotfiles" \
    "$HOME/dev/dotfiles"; do
    [[ -n "$candidate" ]] || continue
    if [[ -f "$candidate/install.sh" && -d "$candidate/config" ]]; then
      readlink -f "$candidate"
      return 0
    fi
  done

  if have git; then
    candidate="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$candidate" && -f "$candidate/install.sh" && -d "$candidate/config" ]]; then
      readlink -f "$candidate"
      return 0
    fi
  fi

  return 1
}

check_managed_link() {
  local src="$1" dst="$2" label="${3:-$2}"

  if [[ ! -e "$src" ]]; then
    fail "$label source is missing: $src"
    return
  fi

  if [[ -L "$dst" && ! -e "$dst" ]]; then
    fail "$label is a broken symlink: $dst"
    return
  fi

  if [[ ! -e "$dst" ]]; then
    warn "$label is not installed: $dst"
    return
  fi

  if same_path "$src" "$dst"; then
    ok "$label"
    return
  fi

  warn "$label differs from repo source: $dst"
}

check_helper() {
  local helper="$1"
  local src="$DOTFILES_DIR/bin/$helper"
  local dst="$HOME/.local/bin/$helper"

  if [[ ! -f "$src" ]]; then
    fail "$helper source is missing: $src"
    return
  fi

  if [[ ! -e "$dst" ]]; then
    warn "$helper is not installed in ~/.local/bin"
    return
  fi

  if [[ ! -x "$dst" ]]; then
    warn "$helper is installed but not executable"
    return
  fi

  if cmp -s "$src" "$dst"; then
    ok "$helper installed"
  else
    warn "$helper in ~/.local/bin differs from repo"
  fi
}

git_config_path_key() {
  case "$1" in
    core.excludesfile|commit.template|gpg.ssh.allowedsignersfile|include.path|includeif.*.path) return 0 ;;
    *) return 1 ;;
  esac
}

normalize_git_config_path() {
  local path="$1"

  case "$path" in
    \~) path="$HOME" ;;
    \~/*) path="$HOME/${path:2}" ;;
  esac

  if [[ "$path" == /* ]] && readlink -m "$path" >/dev/null 2>&1; then
    readlink -m "$path"
  else
    printf '%s\n' "$path"
  fi
}

git_config_values_match() {
  local key="$1" desired="$2" current="$3"

  if [[ "$current" == "$desired" ]]; then
    return 0
  fi

  if git_config_path_key "$key"; then
    [[ "$(normalize_git_config_path "$current")" == "$(normalize_git_config_path "$desired")" ]]
    return
  fi

  return 1
}

check_git_config() {
  local src="$DOTFILES_DIR/config/git/gitconfig"
  local entry key desired current had_issue="no"

  if ! have git; then
    warn "git is not installed; cannot inspect ~/.gitconfig"
    return
  fi
  if [[ ! -f "$src" ]]; then
    fail "repo gitconfig is missing: $src"
    return
  fi

  while IFS= read -r entry; do
    [[ "$entry" == *=* ]] || continue
    key="${entry%%=*}"
    desired="${entry#*=}"
    current="$(git config --global --get "$key" 2>/dev/null || true)"
    if [[ -z "$current" ]]; then
      warn "$HOME/.gitconfig is missing $key=$desired"
      had_issue="yes"
    elif ! git_config_values_match "$key" "$desired" "$current"; then
      if [[ "$key" == "user.signingkey" ]]; then
        info "$HOME/.gitconfig has custom $key=$current"
        continue
      fi
      warn "$HOME/.gitconfig has $key=$current; repo wants $desired"
      had_issue="yes"
    fi
  done < <(git config --file "$src" --list)

  [[ "$had_issue" == "yes" ]] || ok "git global config"
}

codex_root_value() {
  local file="$1" key="$2"
  awk -v key="$key" '
    /^[[:space:]]*\[/ { exit }
    $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      sub("^[[:space:]]*" key "[[:space:]]*=[[:space:]]*", "")
      print
      exit
    }
  ' "$file"
}

codex_table_value() {
  local file="$1" table="$2" key="$3"
  awk -v table="$table" -v key="$key" '
    {
      line = $0
      sub(/^[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
    }
    line == "[" table "]" { in_table = 1; next }
    line ~ /^\[/ { in_table = 0 }
    in_table && $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      sub("^[[:space:]]*" key "[[:space:]]*=[[:space:]]*", "")
      print
      exit
    }
  ' "$file"
}

check_codex_config() {
  local file="$HOME/.codex/config.toml"
  local had_issue="no"
  local key expected actual

  if [[ ! -f "$file" ]]; then
    warn "Codex config is missing: $file"
    return
  fi

  while IFS='|' read -r key expected; do
    actual="$(codex_root_value "$file" "$key")"
    if [[ "$actual" != "$expected" ]]; then
      warn "Codex config wants $key = $expected, found ${actual:-missing}"
      had_issue="yes"
    fi
  done <<'EOF'
sandbox_mode|"danger-full-access"
approval_policy|"never"
EOF

  while IFS='|' read -r key expected; do
    actual="$(codex_table_value "$file" "tui" "$key")"
    if [[ "$actual" != "$expected" ]]; then
      warn "Codex [tui] wants $key = $expected, found ${actual:-missing}"
      had_issue="yes"
    fi
  done <<'EOF'
vim_mode_default|true
status_line|["model-with-reasoning", "current-dir", "context-used", "five-hour-limit", "weekly-limit"]
status_line_use_colors|true
theme|"monokai-extended"
EOF

  while IFS='|' read -r key expected; do
    actual="$(codex_table_value "$file" "tui.keymap.pager" "$key")"
    if [[ "$actual" != "$expected" ]]; then
      warn "Codex [tui.keymap.pager] wants $key = $expected, found ${actual:-missing}"
      had_issue="yes"
    fi
  done <<'EOF'
half_page_down|"d"
half_page_up|"u"
EOF

  [[ "$had_issue" == "yes" ]] || ok "Codex config"
}

check_fonts() {
  local font dst had_issue="no"
  shopt -s nullglob
  for font in "$DOTFILES_DIR"/fonts/*.ttf "$DOTFILES_DIR"/fonts/*.otf; do
    dst="$HOME/.local/share/fonts/$(basename "$font")"
    if [[ ! -f "$dst" ]]; then
      warn "font is not installed: $(basename "$font")"
      had_issue="yes"
    elif ! cmp -s "$font" "$dst"; then
      warn "font differs from repo copy: $(basename "$font")"
      had_issue="yes"
    fi
  done
  shopt -u nullglob

  [[ "$had_issue" == "yes" ]] || ok "bundled fonts"
}

check_niri() {
  local config="$HOME/.config/niri/config.kdl"

  check_managed_link "$DOTFILES_DIR/config/niri/config.kdl" "$config" "niri config"
  check_managed_link "$DOTFILES_DIR/config/niri/keybinds.kdl" "$HOME/.config/niri/keybinds.kdl" "niri keybinds"
  check_managed_link "$DOTFILES_DIR/config/niri/local.example.kdl" "$HOME/.config/niri/local.example.kdl" "niri local example"
  check_managed_link "$DOTFILES_DIR/config/niri-zvim/config.json" "$HOME/.config/niri-zvim/config.json" "niri-zvim config"
  check_managed_link "$DOTFILES_DIR/config/hypr/hyprlock.conf" "$HOME/.config/hypr/hyprlock.conf" "hyprlock config"
  check_managed_link "$DOTFILES_DIR/config/xkb/symbols/usno" "$HOME/.config/xkb/symbols/usno" "xkb usno layout"
  check_managed_link "$DOTFILES_DIR/config/fuzzel/fuzzel.ini" "$HOME/.config/fuzzel/fuzzel.ini" "fuzzel config"
  check_managed_link "$DOTFILES_DIR/config/noctalia/monochrome-strong.json" "$HOME/.config/noctalia/colorschemes/monochrome-strong/monochrome-strong.json" "Noctalia color scheme"

  check_helper niri-focus-workspace-all
  check_helper niri-lock-and-suspend
  check_helper niri-lock-screen
  check_helper niri-move-window-or-workspace
  check_helper niri-screenshot-region
  check_helper noctalia-activate-notification
  check_helper zen-preferences
  check_helper zen-url-handler
  check_zen_url_handler
  check_zen_preferences

  if [[ -f "$HOME/.config/niri/local.kdl" ]]; then
    info "niri local config present: ~/.config/niri/local.kdl"
  else
    info "niri local config not present; repo defaults are in use"
  fi

  if have niri && [[ -f "$config" ]]; then
    if niri validate -c "$config" >/dev/null 2>&1; then
      ok "niri config validates"
    else
      fail "niri config does not validate; run: niri validate -c $config"
    fi
  elif have niri; then
    warn "niri is installed, but ~/.config/niri/config.kdl is missing"
  else
    info "niri is not installed; skipping niri validation"
  fi

  if have niri-zvim; then
    if niri-zvim doctor >/dev/null 2>&1; then
      ok "niri-zvim installation"
    else
      warn "niri-zvim doctor reported a problem; run: niri-zvim doctor"
    fi
  else
    warn "niri-zvim is not installed; rerun ./install.sh --niri"
  fi
}

check_zen_url_handler() {
  local desktop_file="$HOME/.local/share/applications/zen-url-handler.desktop"
  local expected_http="zen-url-handler.desktop"
  local current_http=""
  local current_https=""

  if [[ ! -f "$desktop_file" ]]; then
    warn "Zen Browser desktop integration is not installed: $desktop_file"
    return
  fi

  if have desktop-file-validate; then
    if desktop-file-validate "$desktop_file" >/dev/null 2>&1; then
      ok "Zen Browser desktop entry validates"
    else
      warn "Zen Browser desktop entry does not validate"
    fi
  fi

  if have xdg-mime; then
    current_http="$(xdg-mime query default x-scheme-handler/http 2>/dev/null || true)"
    current_https="$(xdg-mime query default x-scheme-handler/https 2>/dev/null || true)"
    if [[ "$current_http" == "$expected_http" && "$current_https" == "$expected_http" ]]; then
      ok "Zen Browser is default for http/https"
    else
      warn "http/https defaults are $current_http/$current_https; expected $expected_http"
    fi
  else
    warn "xdg-mime is not installed; cannot inspect browser defaults"
  fi
}

check_zen_preferences() {
  local helper="$DOTFILES_DIR/bin/zen-preferences"

  if [[ ! -x "$helper" ]]; then
    warn "Zen preferences helper is not executable: $helper"
    return
  fi

  if "$helper" --check >/dev/null 2>&1; then
    ok "Zen preferences"
  else
    warn "Zen preferences need update; run: zen-preferences"
  fi
}

DOTFILES_DIR="$(resolve_dotfiles_dir || true)"
if [[ -z "$DOTFILES_DIR" ]]; then
  fail "could not locate dotfiles repo; set DOTFILES_DIR=/path/to/dotfiles"
  print_summary
  exit 1
fi

section "repo"
ok "repo: $DOTFILES_DIR"
if have git && git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  if [[ -n "$(git -C "$DOTFILES_DIR" status --short)" ]]; then
    warn "repo has uncommitted changes"
  else
    ok "repo working tree clean"
  fi
else
  warn "repo is not a git working tree"
fi

section "shell environment"
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ok "$HOME/.local/bin is on PATH" ;;
  *) warn "$HOME/.local/bin is not on PATH" ;;
esac

for cmd in git zsh starship nvim hx yazi zellij atuin direnv just jq rg taplo pwsh; do
  if [[ "$cmd" == "hx" ]] && ! have hx && have helix; then
    ok "hx: $(command -v helix) (installed as helix)"
  elif have "$cmd"; then
    ok "$cmd: $(command -v "$cmd")"
  else
    warn "$cmd is not installed or not on PATH"
  fi
done

if have pwsh; then
  if TERM=dumb pwsh -NoLogo -NoProfile -NonInteractive -Command \
    'if (Get-Module -ListAvailable -Name PSScriptAnalyzer) { exit 0 }; exit 1' >/dev/null 2>&1; then
    ok "PSScriptAnalyzer"
  else
    warn "PSScriptAnalyzer is not installed for PowerShell"
  fi
fi

section "managed config"
check_managed_link "$DOTFILES_DIR/config/atuin/config.toml" "$HOME/.config/atuin/config.toml" "atuin config"
check_managed_link "$DOTFILES_DIR/config/atuin/themes" "$HOME/.config/atuin/themes" "atuin themes"
check_managed_link "$DOTFILES_DIR/config/broot/conf.toml" "$HOME/.config/broot/conf.toml" "broot config"
check_managed_link "$DOTFILES_DIR/config/broot/skins" "$HOME/.config/broot/skins" "broot skins"
check_managed_link "$DOTFILES_DIR/config/codex/AGENTS.md" "$HOME/.codex/AGENTS.md" "Codex instructions"
check_managed_link "$DOTFILES_DIR/config/codex/skills/gh-publish" "$HOME/.codex/skills/gh-publish" "Codex GitHub publish skill"
check_managed_link "$DOTFILES_DIR/config/copilot/copilot-instructions.md" "$HOME/.copilot/copilot-instructions.md" "Copilot instructions"
check_managed_link "$DOTFILES_DIR/config/git/ignore" "$HOME/.config/git/ignore" "git ignore"
check_managed_link "$DOTFILES_DIR/config/helix/config.toml" "$HOME/.config/helix/config.toml" "helix config"
check_managed_link "$DOTFILES_DIR/config/helix/languages.toml" "$HOME/.config/helix/languages.toml" "helix languages"
check_managed_link "$DOTFILES_DIR/config/nvim" "$HOME/.config/nvim" "neovim config"
check_managed_link "$DOTFILES_DIR/config/starship/zsh/starship.toml" "$HOME/.config/starship.toml" "starship config"
check_managed_link "$DOTFILES_DIR/config/tealdeer/config.toml" "$HOME/.config/tealdeer/config.toml" "tealdeer config"
check_managed_link "$DOTFILES_DIR/config/yazi" "$HOME/.config/yazi" "yazi config"
check_managed_link "$DOTFILES_DIR/config/zellij" "$HOME/.config/zellij" "zellij config"
check_managed_link "$DOTFILES_DIR/shells/.zshrc" "$HOME/.zshrc" "zsh config"
check_managed_link "$DOTFILES_DIR/shells/.zprofile" "$HOME/.zprofile" "zsh login config"
if same_path "$DOTFILES_DIR/shells/.bashrc" "$HOME/.bashrc"; then
  check_managed_link "$DOTFILES_DIR/shells/.bashrc" "$HOME/.bashrc" "bash config"
elif ! is_wsl && is_debian_like; then
  check_managed_link "$DOTFILES_DIR/shells/.bashrc" "$HOME/.bashrc" "bash config"
else
  info "bash config is not managed on this platform"
fi
if ! is_wsl; then
  check_managed_link "$DOTFILES_DIR/config/alacritty/alacritty.toml" "$HOME/.config/alacritty/alacritty.toml" "alacritty config"
  check_managed_link "$DOTFILES_DIR/config/wezterm/wezterm.lua" "$HOME/.config/wezterm/wezterm.lua" "wezterm config"
  check_managed_link "$DOTFILES_DIR/config/ghostty/config.ghostty" "$HOME/.config/ghostty/config.ghostty" "ghostty config"
  check_managed_link "$DOTFILES_DIR/config/ghostty/shaders" "$HOME/.config/ghostty/shaders" "ghostty shaders"
fi

section "managed helpers"
check_helper dotfiles-doctor

section "merged config"
check_git_config
check_codex_config

section "fonts"
check_fonts

if [[ -e "$HOME/.config/niri/config.kdl" ]] || have niri; then
  section "niri desktop"
  check_niri
fi

print_summary
if ((failures > 0)); then
  exit 1
fi
