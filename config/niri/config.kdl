input {
    focus-follows-mouse max-scroll-amount="33%"

    keyboard {
        xkb {
            layout "usno"
        }
        numlock
    }

    touchpad {
        dwt
        tap
        natural-scroll
    }

    mouse {
        accel-profile "flat"
        accel-speed -0.7
    }
    trackpoint
}

layout {
    gaps 8

    // Noctalia draws the wallpaper.
    background-color "transparent"

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 1
        active-color "#ededed"
        inactive-color "#505050"
    }

    border {
        width 1
        active-color "#ededed"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }

    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }

    struts
}

// Noctalia v4 shell.
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface color-scheme prefer-dark && exec qs -c noctalia-shell"

// Lightweight polkit auth agent for GUI elevation prompts.
spawn-at-startup "/usr/libexec/xfce-polkit"

hotkey-overlay {
    skip-at-startup
}

debug {
    // Allows notification actions and window activation from Noctalia.
    honor-xdg-activation-with-invalid-serial
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

animations

overview {
    workspace-shadow {
        off
    }
}

blur {
    passes 2
    offset 3.0
    noise 0.03
    saturation 1.0
}

window-rule { clip-to-geometry true; geometry-corner-radius 2; }

window-rule {
    geometry-corner-radius 9
    clip-to-geometry true
    background-effect {
        blur true
        xray false
    }
}

window-rule {
    match app-id="com.mitchellh.ghostty"
    draw-border-with-background false
}

layer-rule {
    match namespace="^noctalia-wallpaper*"
    place-within-backdrop true
}

layer-rule {
    match namespace="^noctalia-(background|launcher-overlay|dock)-.*$"

    background-effect {
        xray false
    }
}

// Work around WezTerm's initial configure bug.
window-rule {
    match app-id=r"^org\.wezfurlong\.wezterm$"
    default-column-width
}

window-rule {
    match app-id=r"firefox$" title="^Picture-in-Picture$"
    open-floating true
}

include "keybinds.kdl"

prefer-no-csd

// Keep outputs, renderer device choices, and host-specific tweaks local.
include "local.kdl" optional=true
