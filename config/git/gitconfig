[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    line-numbers = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers

[user]
    signingKey = ~/.ssh/id_ed25519.pub

[commit]
    gpgSign = true
